# Server Configuration
PORT=5000

# JWT Secret - Change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Google OAuth
# Get your Client ID from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=566283033694-2m7n5phsho0icok735g6jkgrbld19hhe.apps.googleusercontent.com
VITE_FACEBOOK_APP_ID=2883809181964066
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth
# Get your App ID from: https://developers.facebook.com/
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Client URL (only needed when frontend and API use different origins)
CLIENT_URL=http://localhost:3001

# PostgreSQL database (use a separate development database locally)
DATABASE_URL=postgresql://user:password@localhost:5432/webstore?schema=public

# Node Environment
NODE_ENV=development

# Optional demo seed credentials
DEMO_ADMIN_PASSWORD=change-this-admin-password
DEMO_USER_PASSWORD=DemoUser123!

# Persistent media storage
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
